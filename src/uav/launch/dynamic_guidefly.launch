<?xml version="1.0"?>
<launch>
    <!-- 启动 rqt_gui -->
    <node name="rqt_gui" pkg="rqt_gui" type="rqt_gui" args="-s rqt_reconfigure" output="screen">
        <env name="ROS_NAMESPACE" value=""/>
        <param name="use_sim_time" type="bool" value="false"/>
    </node>
    <node pkg="uav" type="dynamic_guidefly" name="dynamic_guidefly"   output="screen" />
</launch>